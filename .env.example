# Port to listen on (default: 3000)
PORT=3000

# Password Authentik will use to authenticate with this adaptor.
# Authentik Generic SMS → Auth Type: HTTP Basic or Bearer, password = this value.
ADAPTOR_PASSWORD=change_me_to_something_strong

# Base URL of your Vendel instance (no trailing slash)
VENDEL_URL=http://vendel:8090

# Vendel API key (starts with vk_)
VENDEL_API_KEY=vk_your_api_key_here
